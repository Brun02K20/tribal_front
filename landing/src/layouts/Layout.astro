---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Tribal Trend | Tienda Online de Artesanias',
	description = 'Tribal Trend: tienda online de artesanias, regalos y decoracion hecha a mano en Argentina.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=MedievalSharp&family=Oldenburg&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" href="/icons/logo_tribal_trnasparente.png" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--color-cream: #f8f3e7;
		--color-dark-gray: #2f2f2f;
		--color-black: #111111;
		--color-earth-brown: #7a4a2b;
		--color-earth-brown-soft: #9a7b5a;
		--color-line: #d7c8b2;
		--shadow-soft: 0 12px 26px rgba(47, 47, 47, 0.08);
		--shadow-strong: 0 16px 30px rgba(47, 47, 47, 0.12);
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		scroll-behavior: smooth;
	}

	body {
		color: var(--color-dark-gray);
		background:
			radial-gradient(circle at 10% 10%, rgba(154, 123, 90, 0.16), transparent 42%),
			radial-gradient(circle at 90% 18%, rgba(122, 74, 43, 0.14), transparent 38%),
			linear-gradient(180deg, rgba(248, 243, 231, 0.94) 0%, rgba(248, 243, 231, 1) 100%);
		font-family: 'Oldenburg', serif;
	}

	h1,
	h2,
	h3,
	h4 {
		color: var(--color-black);
		font-family: 'MedievalSharp', serif;
		letter-spacing: 0.02em;
		margin: 0;
	}

	p {
		line-height: 1.55;
		margin: 0;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.app-shell {
		margin: 0 auto;
		max-width: 1200px;
		padding: 1.25rem;
	}

	.app-panel {
		border: 1px solid var(--color-line);
		background: rgba(255, 255, 255, 0.84);
		backdrop-filter: blur(4px);
		border-radius: 14px;
		box-shadow: var(--shadow-soft);
		transition: transform 0.22s ease, box-shadow 0.22s ease;
	}

	.app-panel:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-strong);
	}

	.app-btn-primary,
	.app-btn-secondary {
		border-radius: 10px;
		cursor: pointer;
		display: inline-flex;
		font-family: 'Oldenburg', serif;
		font-size: 1rem;
		font-weight: 600;
		gap: 0.45rem;
		justify-content: center;
		padding: 0.7rem 1rem;
		transition: transform 0.22s ease, box-shadow 0.22s ease, background-color 0.22s ease;
	}

	.app-btn-primary {
		background: var(--color-earth-brown);
		border: 1px solid var(--color-earth-brown);
		box-shadow: 0 6px 16px rgba(47, 47, 47, 0.16);
		color: var(--color-cream);
	}

	.app-btn-primary:hover {
		background: var(--color-black);
		border-color: var(--color-black);
		box-shadow: 0 0 0 1px rgba(122, 74, 43, 0.22), 0 8px 18px rgba(47, 47, 47, 0.22), 0 0 18px rgba(122, 74, 43, 0.35);
		transform: translateY(-1px);
	}

	.app-btn-secondary {
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid var(--color-earth-brown);
		box-shadow: 0 4px 12px rgba(47, 47, 47, 0.08);
		color: var(--color-earth-brown);
	}

	.app-btn-secondary:hover {
		background: rgba(122, 74, 43, 0.12);
		transform: translateY(-1px);
	}

	.app-input {
		background: rgba(255, 255, 255, 0.96);
		border: 1px solid rgba(122, 74, 43, 0.42);
		border-radius: 10px;
		box-shadow: 0 4px 10px rgba(47, 47, 47, 0.08);
		color: var(--color-black);
		font: inherit;
		padding: 0.7rem 0.75rem;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
		width: 100%;
	}

	.app-input:focus {
		border-color: var(--color-earth-brown);
		box-shadow: 0 0 0 2px rgba(122, 74, 43, 0.18), 0 8px 16px rgba(47, 47, 47, 0.12), 0 0 14px rgba(122, 74, 43, 0.25);
		outline: none;
	}

	.section-title {
		font-size: clamp(1.7rem, 2.4vw, 2.3rem);
		margin-bottom: 0.6rem;
	}

	.section-lead {
		max-width: 760px;
		opacity: 0.9;
	}
	@media (max-width: 800px) {
		.app-shell {
			padding: 1rem;
		}
	}
</style>
