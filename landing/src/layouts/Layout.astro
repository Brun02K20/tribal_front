---
interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	canonicalPath?: string;
	ogType?: 'website' | 'article';
	noindex?: boolean;
	additionalJsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title = 'Tribal Trend | Tienda Online de Artesanias',
	description = 'Tribal Trend: tienda de arte, decoraciones y artesanias con envios a Cordoba y toda Argentina.',
	keywords = 'arte, decoraciones, artesanias, tienda de artesanias, tienda de arte, regalos artesanales, cordoba, argentina',
	canonicalPath = Astro.url.pathname,
	ogType = 'website',
	noindex = false,
	additionalJsonLd,
} = Astro.props;

const siteUrl = (import.meta.env.SITE_URL ?? 'https://tribaltrend.com.ar').replace(/\/+$/, '');
const canonicalUrl = `${siteUrl}${canonicalPath.startsWith('/') ? canonicalPath : `/${canonicalPath}`}`;
const ogImagePath = '/icons/logo_tribal_trnasparente.png';
const ogImageUrl = `${siteUrl}${ogImagePath}`;
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Store',
  name: 'Tribal Trend',
  url: siteUrl,
  logo: ogImageUrl,
  image: [ogImageUrl],
  description,
};

const jsonLdPayload = Array.isArray(additionalJsonLd)
  ? [organizationJsonLd, ...additionalJsonLd]
  : additionalJsonLd
    ? [organizationJsonLd, additionalJsonLd]
    : [organizationJsonLd];
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:locale" content="es_AR" />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Tribal Trend" />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content="Logo Tribal Trend" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=MedievalSharp&family=Oldenburg&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" href="/icons/logo_tribal_trnasparente.png" />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLdPayload)}></script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--color-cream: #f8f3e7;
		--color-dark-gray: #2f2f2f;
		--color-black: #111111;
		--color-earth-brown: #7a4a2b;
		--color-earth-brown-soft: #9a7b5a;
		--color-line: #d7c8b2;
		--shadow-soft: 0 12px 26px rgba(47, 47, 47, 0.08);
		--shadow-strong: 0 16px 30px rgba(47, 47, 47, 0.12);
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		scroll-behavior: smooth;
	}

	body {
		color: var(--color-dark-gray);
		background:
			linear-gradient(
				180deg,
				rgba(248, 243, 231, 0.36) 0%,
				rgba(248, 243, 231, 0.5) 100%
			),
			url('/assets/background.png');
		background-repeat: no-repeat;
		background-size: cover;
		background-position: center;
		background-attachment: fixed;
		font-family: 'Oldenburg', serif;
		overflow-x: hidden;
		position: relative;
	}

	body::before {
		content: '';
		position: fixed;
		right: -4vw;
		bottom: -8vh;
		transform: scaleX(-1);
		width: clamp(160px, 22vw, 420px);
		aspect-ratio: 1 / 1;
		background-image: url('/assets/leaf-svgrepo-com.svg');
		background-repeat: no-repeat;
		background-position: right bottom;
		background-size: contain;
		opacity: 0.78;
		pointer-events: none;
		z-index: 0;
	}

	body::after {
		content: '';
		position: fixed;
		left: 50%;
		top: 52%;
		transform: translate(-50%, -50%);
		width: clamp(280px, 52vw, 980px);
		aspect-ratio: 1 / 1;
		background-image: url('/icons/logo_tribal_trnasparente.png');
		background-repeat: no-repeat;
		background-position: center;
		background-size: contain;
		opacity: 0.34;
		pointer-events: none;
		z-index: 0;
	}

	body > * {
		position: relative;
		z-index: 2;
	}

	h1,
	h2,
	h3,
	h4 {
		color: var(--color-black);
		font-family: 'MedievalSharp', serif;
		letter-spacing: 0.02em;
		margin: 0;
	}

	p {
		line-height: 1.55;
		margin: 0;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.app-shell {
		margin: 0 auto;
		max-width: 1200px;
		padding: 1.25rem;
	}

	.app-panel {
		border: 1px solid var(--color-line);
		background: rgba(255, 255, 255, 0.84);
		backdrop-filter: blur(4px);
		border-radius: 14px;
		box-shadow: var(--shadow-soft);
		transition: transform 0.22s ease, box-shadow 0.22s ease;
	}

	.app-panel:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-strong);
	}

	.app-btn-primary,
	.app-btn-secondary {
		border-radius: 10px;
		cursor: pointer;
		display: inline-flex;
		font-family: 'Oldenburg', serif;
		font-size: 1rem;
		font-weight: 600;
		gap: 0.45rem;
		justify-content: center;
		padding: 0.7rem 1rem;
		transition: transform 0.22s ease, box-shadow 0.22s ease, background-color 0.22s ease;
	}

	.app-btn-primary {
		background: var(--color-earth-brown);
		border: 1px solid var(--color-earth-brown);
		box-shadow: 0 6px 16px rgba(47, 47, 47, 0.16);
		color: var(--color-cream);
	}

	.app-btn-primary:hover {
		background: var(--color-black);
		border-color: var(--color-black);
		box-shadow: 0 0 0 1px rgba(122, 74, 43, 0.22), 0 8px 18px rgba(47, 47, 47, 0.22), 0 0 18px rgba(122, 74, 43, 0.35);
		transform: translateY(-1px);
	}

	.app-btn-secondary {
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid var(--color-earth-brown);
		box-shadow: 0 4px 12px rgba(47, 47, 47, 0.08);
		color: var(--color-earth-brown);
	}

	.app-btn-secondary:hover {
		background: rgba(122, 74, 43, 0.12);
		transform: translateY(-1px);
	}

	.app-input {
		background: rgba(255, 255, 255, 0.96);
		border: 1px solid rgba(122, 74, 43, 0.42);
		border-radius: 10px;
		box-shadow: 0 4px 10px rgba(47, 47, 47, 0.08);
		color: var(--color-black);
		font: inherit;
		padding: 0.7rem 0.75rem;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
		width: 100%;
	}

	.app-input:focus {
		border-color: var(--color-earth-brown);
		box-shadow: 0 0 0 2px rgba(122, 74, 43, 0.18), 0 8px 16px rgba(47, 47, 47, 0.12), 0 0 14px rgba(122, 74, 43, 0.25);
		outline: none;
	}

	.section-title {
		font-size: clamp(1.7rem, 2.4vw, 2.3rem);
		margin-bottom: 0.6rem;
	}

	.section-lead {
		max-width: 760px;
		opacity: 0.9;
	}
	@media (max-width: 800px) {
		.app-shell {
			padding: 1rem;
		}
	}
</style>
