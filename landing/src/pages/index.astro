---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Tribal Trend | Tu Tienda Online Siempre Disponible"
	description="Tienda de arte, decoraciones y artesanias. Compra en Cordoba y toda Argentina con envios y atencion personalizada."
	keywords="arte, decoraciones, artesanias, tienda de artesanias, tienda de arte, cordoba, argentina"
	canonicalPath="/"
>
	<main class="app-shell">
		<header class="hero app-panel">
			<nav class="nav">
				<a class="brand" href="#inicio">Tribal Trend</a>
				<div class="nav-links">
					<a href="#beneficios">Beneficios</a>
					<a href="#testimonios">Testimonios</a>
					<a href="/preguntas-frecuentes">FAQ</a>
					<a class="app-btn-secondary" href="/tienda">Ir a la tienda</a>
				</div>
			</nav>

			<section id="inicio" class="hero-content">
				<div class="hero-copy">
					<p class="eyebrow">Tienda online de artesanias en Argentina</p>
					<h1>Compra regalos originales y decoracion artesanal con confianza</h1>
					<p class="section-lead">
						Descubri piezas de arte, decoraciones y artesanias para tu hogar o para regalar.
						Elegi tus favoritos y recibilos en Cordoba y toda Argentina.
					</p>
					<div class="hero-cta">
						<a class="app-btn-primary" href="/tienda">Comprar ahora</a>
						<a class="app-btn-secondary" href="/preguntas-frecuentes">Ver preguntas frecuentes</a>
					</div>
				</div>
				<div class="hero-logo-wrap">
					<img
						src="/icons/logo_tribal_trnasparente.png"
						alt="Tribal Trend tienda online de artesanias y regalos originales"
						class="hero-logo"
						width="720"
						height="720"
						fetchpriority="high"
						loading="eager"
						decoding="async"
					/>
				</div>
			</section>
		</header>

		<section id="beneficios" class="section">
			<h2 class="section-title">Por que elegir nuestra tienda online de artesanias</h2>
			<div class="benefits-grid">
				<article class="app-panel benefit-card">
					<h3>Productos hechos a mano</h3>
					<p>Arte y artesanias con estilo propio para decorar espacios y sorprender con regalos unicos.</p>
				</article>
				<article class="app-panel benefit-card">
					<h3>Compra simple y segura</h3>
					<p>Elegi tus productos, realizá tu pedido y segui todo el proceso de forma clara y rapida.</p>
				</article>
				<article class="app-panel benefit-card">
					<h3>Envios en Cordoba y Argentina</h3>
					<p>Recibi tus compras donde estes, con atencion cercana para cualquier duda sobre tu pedido.</p>
				</article>
			</div>
		</section>

		<section id="testimonios" class="section">
			<h2 class="section-title">Opiniones reales de clientes sobre Tribal Trend</h2>
			<div class="testimonials-grid">
				<blockquote class="app-panel testimonial">
					<p>"Compre decoraciones para mi casa y llegaron tal como se veian en la tienda. Hermoso todo."</p>
					<footer>- Mariana, Cordoba</footer>
				</blockquote>
				<blockquote class="app-panel testimonial">
					<p>"Pedi un regalo artesanal de ultimo momento y la atencion fue excelente. Volvere a comprar."</p>
					<footer>- Lucas, Buenos Aires</footer>
				</blockquote>
				<blockquote class="app-panel testimonial">
					<p>"La tienda tiene productos originales y faciles de encontrar. Muy buena experiencia de compra."</p>
					<footer>- Sofia, Rosario</footer>
				</blockquote>
			</div>
		</section>

		<section id="contacto" class="section contact-section app-panel">
			<div class="contact-copy">
				<h2 class="section-title">Tenes dudas sobre un producto o envio</h2>
				<p class="section-lead">
					Completá el formulario y te respondemos para ayudarte con tu compra en la tienda.
				</p>
			</div>

			<form id="contactForm" class="contact-form">
				<label>
					Nombre
					<input class="app-input" type="text" name="nombre" required />
				</label>
				<label>
					Email
					<input class="app-input" type="email" name="email" required />
				</label>
				<label>
					Telefono
					<input class="app-input" type="text" name="telefono" />
				</label>
				<label>
					Mensaje
					<textarea class="app-input" name="mensaje" rows="5" required></textarea>
				</label>
				<button class="app-btn-primary" type="submit">Enviar consulta</button>
				<p id="formStatus" class="form-status" aria-live="polite"></p>
			</form>
		</section>
	</main>

	<script>
		const form = document.getElementById('contactForm');
		const status = document.getElementById('formStatus');

		if (!(form instanceof HTMLFormElement) || !(status instanceof HTMLElement)) {
			throw new Error('No se encontraron los elementos del formulario de contacto.');
		}

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
			if (!submitButton || !status) {
				return;
			}

			submitButton.setAttribute('disabled', 'true');
			status.textContent = 'Enviando...';

			const formData = new FormData(form);
			const payload = {
				nombre: String(formData.get('nombre') ?? ''),
				email: String(formData.get('email') ?? ''),
				telefono: String(formData.get('telefono') ?? ''),
				mensaje: String(formData.get('mensaje') ?? ''),
			};

			try {
				const response = await fetch('/api/contact', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});

				const result = await response.json();
				if (!response.ok || !result.ok) {
					throw new Error(result.message ?? 'No se pudo enviar el mensaje.');
				}

				form.reset();
				status.textContent = 'Mensaje enviado. Te contactaremos pronto.';
			} catch (error) {
				status.textContent =
					error instanceof Error ? error.message : 'No se pudo enviar el mensaje en este momento.';
			} finally {
				submitButton.removeAttribute('disabled');
			}
		});
	</script>
</Layout>

<style>
	.hero {
		padding: 1.1rem;
	}

	.nav {
		align-items: center;
		display: flex;
		gap: 1rem;
		justify-content: space-between;
	}

	.brand {
		color: var(--color-black);
		font-family: 'MedievalSharp', serif;
		font-size: 1.3rem;
	}

	.nav-links {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
	}

	.hero-content {
		align-items: center;
		display: grid;
		gap: 1rem;
		grid-template-columns: 1.2fr 0.8fr;
		margin-top: 1rem;
	}

	.eyebrow {
		color: var(--color-earth-brown);
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	h1 {
		font-size: clamp(2rem, 4vw, 3.2rem);
		margin-bottom: 0.7rem;
		margin-top: 0.4rem;
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 1rem;
	}

	.hero-logo-wrap {
		align-items: center;
		display: flex;
		justify-content: center;
		min-height: 260px;
	}

	.hero-logo {
		animation: float-in 0.8s ease-out;
		width: min(100%, 360px);
		height: auto;
		aspect-ratio: 1 / 1;
		object-fit: contain;
	}

	.section {
		margin-top: 1.6rem;
	}

	.benefits-grid,
	.testimonials-grid {
		display: grid;
		gap: 0.85rem;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		margin-top: 0.85rem;
	}

	.benefit-card,
	.testimonial {
		padding: 1rem;
	}

	.benefit-card h3 {
		margin-bottom: 0.35rem;
	}

	.testimonial footer {
		color: var(--color-earth-brown);
		margin-top: 0.6rem;
	}

	.contact-section {
		align-items: start;
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr 1fr;
		padding: 1rem;
	}

	.contact-form {
		display: grid;
		gap: 0.72rem;
	}

	.contact-form label {
		display: grid;
		gap: 0.35rem;
	}

	.form-status {
		min-height: 1.2rem;
		opacity: 0.95;
	}

	@keyframes float-in {
		from {
			opacity: 0;
			transform: translateY(10px) scale(0.97);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@media (max-width: 980px) {
		.hero-content,
		.contact-section {
			grid-template-columns: 1fr;
		}

		.benefits-grid,
		.testimonials-grid {
			grid-template-columns: 1fr;
		}

		.hero-logo {
			max-width: 300px;
		}
	}
</style>
