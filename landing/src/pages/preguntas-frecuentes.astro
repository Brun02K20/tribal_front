---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: 'Que puedo comprar en Tribal Trend?',
    a: 'En Tribal Trend vas a encontrar arte, decoraciones y artesanias para regalar o decorar tu hogar.',
  },
  {
    q: 'La tienda esta disponible todo el tiempo?',
    a: 'Si. Podes comprar online las 24 horas, todos los dias.',
  },
  {
    q: 'Como funciona la atencion al cliente?',
    a: 'Te ayudamos con dudas sobre productos, pagos, envios y seguimiento de pedidos.',
  },
  {
    q: 'A que zonas realizan envios?',
    a: 'Realizamos envios en Cordoba y en todo el territorio de Argentina.',
  },
  {
    q: 'Como me contacto si tengo una consulta?',
    a: 'En la landing principal tenes un formulario de contacto. Completa tus datos y te respondemos a la brevedad.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<Layout
  title="Preguntas frecuentes | Arte, decoraciones y artesanias"
  description="Resuelve dudas sobre arte, decoraciones y artesanias: compras online, envios en Cordoba y Argentina, y atencion al cliente."
  keywords="preguntas frecuentes, arte, decoraciones, artesanias, tienda de artesanias, cordoba, argentina"
  canonicalPath="/preguntas-frecuentes"
  ogType="article"
  additionalJsonLd={faqJsonLd}
>
  <main class="app-shell faq-wrap">
    <header class="faq-header app-panel">
      <h1>Preguntas frecuentes sobre comprar artesanias online</h1>
      <p class="section-lead">Todo lo que necesitas saber para comprar en la tienda de forma simple.</p>
      <div class="faq-links">
        <a class="app-btn-secondary" href="/">Volver a la landing</a>
        <a class="app-btn-primary" href="/tienda">Ir a la tienda</a>
      </div>
    </header>

    <section class="faq-list">
      {faqs.map((item) => (
        <article class="app-panel faq-item">
          <h2>{item.q}</h2>
          <p>{item.a}</p>
        </article>
      ))}
    </section>
  </main>
</Layout>

<style>
  .faq-wrap {
    display: grid;
    gap: 1rem;
    padding-block: 1rem 2rem;
  }

  .faq-header {
    padding: 1rem;
  }

  .faq-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .faq-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 0.9rem;
  }

  .faq-list {
    display: grid;
    gap: 0.7rem;
  }

  .faq-item {
    padding: 1rem;
  }

  .faq-item h2 {
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
  }
</style>
